# Cloudflare Pages 配置文件
# 更多信息：https://developers.cloudflare.com/pages/functions/build-configuration/

[build]
  # 构建命令
  command = "export DEPLOY_TARGET=cloudflare && npm run build"

  # 构建输出目录
  publish = "out"

  # 环境变量
  [build.environment]
  NODE_ENV = "production"
  DEPLOY_TARGET = "cloudflare"

# 重定向规则（SPA 路由支持）
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
  force = false

# 头部设置（可选）
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
    X-XSS-Protection = "1; mode=block"
    Referrer-Policy = "strict-origin-when-cross-origin"
