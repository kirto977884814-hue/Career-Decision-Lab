## 2）解释引擎：生成“能力拆解表 + 差距分析”

```ts
// explain.ts
import { PATHS, GATE_RULES } from "./model";
import type { DimKey, PathKey } from "./model";
import { DIM_META } from "./dimensions";

const ORDER: DimKey[] = ["S","A","R","E","X","C"];
const idx: Record<DimKey, number> = { S:0, A:1, R:2, E:3, X:4, C:5 };

// 把 0~1 的用户分数映射成“等级”
function level(u01: number) {
  if (u01 >= 0.75) return "高";      // >=4.0
  if (u01 >= 0.50) return "中";      // >=3.0
  if (u01 >= 0.35) return "偏低";    // >=2.4
  return "低";
}

function status(required: number, u01: number) {
  // required: 0~5 权重 -> 用区间映射成期望门槛
  // 权重>=4：期望高；权重=3：期望中；<=2：不作为核心
  const need = required >= 4 ? 0.60 : required === 3 ? 0.45 : 0.0;
  if (need === 0.0) return { tag: "非核心", note: "该维度不是这条路径的核心要求。" };

  if (u01 >= need + 0.10) return { tag: "优势", note: "你的该维度高于该路径要求区间。" };
  if (u01 >= need) return { tag: "可用", note: "该维度达到该路径基本要求，可通过实践增强。" };
  return { tag: "差距", note: "该维度低于该路径的典型要求，是优先补强点。" };
}

export function buildPathExplanation(params: {
  path: PathKey;
  u01: number[]; // 0~1，顺序与 ORDER 一致
}) {
  const { path, u01 } = params;
  const w = PATHS[path];
  const rule = GATE_RULES[path];

  // 1) 拆解表（6行）
  const breakdown = ORDER.map((k) => {
    const required = w[idx[k]];
    const st = status(required, u01[idx[k]]);
    return {
      key: k,
      name: DIM_META[k].name,
      requiredWeight: required,       // 0~5
      you: u01[idx[k]],               // 0~1
      youLevel: level(u01[idx[k]]),   // 高/中/偏低/低
      status: st.tag,                 // 优势/可用/差距/非核心
      note: st.note,
    };
  });

  // 2) 关键维度检查（用于“为什么匹配/为什么要注意”）
  const k1 = rule.keys[0] as DimKey;
  const k2 = rule.keys[1] as DimKey;
  const keyAvg = (u01[idx[k1]] + u01[idx[k2]]) / 2;

  // 3) 差距优先级：在“核心维度”里找差距最大的两个
  const coreDims = breakdown
    .filter(b => b.requiredWeight >= 4) // 核心要求
    .sort((a,b) => (a.you - b.you));    // 从低到高

  const topGaps = coreDims
    .filter(b => b.status === "差距")
    .slice(0, 2)
    .map(b => ({
      key: b.key,
      name: b.name,
      why: `该路径在「${b.name}」上权重较高，但你当前水平为「${b.youLevel}」。`,
      improve: DIM_META[b.key].improve,
    }));

  // 4) 自动生成总结句（用于结果页文案）
  const summary = {
    fit: `这条路径的关键维度是「${DIM_META[k1].name}」与「${DIM_META[k2].name}」。你在这两项上的整体水平为「${level(keyAvg)}」。`,
    caution:
      topGaps.length > 0
        ? `需要优先补强：${topGaps.map(g => g.name).join("、")}，否则会限制该路径的成长上限。`
        : `当前核心维度已达到基本要求，建议通过项目实践验证与迭代。`,
  };

  return { breakdown, topGaps, summary };
}
```

