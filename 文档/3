## 3）Top1 vs Top2 对比解释（自动生成）

```ts
// compare.ts
import type { PathKey } from "./model";
import type { DimKey } from "./dimensions";
import { PATHS } from "./model";
import { DIM_META } from "./dimensions";

const ORDER: DimKey[] = ["S","A","R","E","X","C"] as const;
const idx: Record<DimKey, number> = { S:0,A:1,R:2,E:3,X:4,C:5 };

export function compareTopPaths(u01: number[], top1: PathKey, top2: PathKey) {
  const w1 = PATHS[top1];
  const w2 = PATHS[top2];

  // 找出两条路径“需求差异最大”的两个维度，用于解释为什么Top1赢
  const diffs = ORDER.map(k => {
    const d = w1[idx[k]] - w2[idx[k]];
    return { k, diff: d, you: u01[idx[k]] };
  }).sort((a,b)=> Math.abs(b.diff) - Math.abs(a.diff));

  const keyDiffs = diffs.slice(0,2).map(d => {
    const dim = d.k;
    const more = d.diff > 0 ? top1 : top2; // 哪条更看重这个维度
    return {
      dim,
      dimName: DIM_META[dim].name,
      more,
      you: u01[idx[dim]],
    };
  });

  return {
    text: `Top1 与 Top2 的主要差异在「${keyDiffs[0].dimName}、${keyDiffs[1].dimName}」。你的能力结构在这些维度上更接近 Top1 的要求，因此当前更推荐 Top1。`,
    keyDiffs,
  };
}
```

