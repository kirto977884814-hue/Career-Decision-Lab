## 4）【直接可用】评分代码（TS/JS都能用）

把你项目里原来的 `calculateScores / getTopPath` 全换成这个文件即可。

### `model.ts`

```ts
// model.ts
export type DimKey = "S" | "A" | "R" | "E" | "X" | "C";
export const ORDER: DimKey[] = ["S","A","R","E","X","C"];

export const PATHS = {
  stable:            [5, 1, 1, 2, 5, 3],
  deepSpecialist:    [5, 5, 1, 1, 3, 1],
  techApplication:   [3, 5, 2, 1, 5, 1],
  productStrategy:   [5, 4, 2, 5, 2, 2],
  growthOperation:   [2, 2, 5, 4, 5, 1],
  contentExpression: [1, 2, 3, 5, 2, 5],
  educationSupport:  [4, 1, 1, 4, 2, 5],
  entrepreneurship:  [2, 2, 5, 3, 5, 1],
} as const;

export const GATE_RULES = {
  stable:            { keys: ["S","X"], veto: null as DimKey | null },
  deepSpecialist:    { keys: ["A","S"], veto: "E" as DimKey },
  techApplication:   { keys: ["A","X"], veto: "E" as DimKey },
  productStrategy:   { keys: ["S","E"], veto: "A" as DimKey },
  growthOperation:   { keys: ["X","R"], veto: "A" as DimKey },
  contentExpression: { keys: ["E","C"], veto: "A" as DimKey },
  educationSupport:  { keys: ["C","E"], veto: "R" as DimKey },
  entrepreneurship:  { keys: ["R","X"], veto: "C" as DimKey },
} as const;

export type PathKey = keyof typeof PATHS;

export type DimScores = Record<DimKey, number>; // 1~5

const idx: Record<DimKey, number> = { S:0, A:1, R:2, E:3, X:4, C:5 };

function normalize01(x: number): number {
  // 1~5 -> 0~1
  return (x - 1) / 4;
}

function mean(v: number[]): number {
  return v.reduce((a,b)=>a+b,0) / v.length;
}

function norm(v: number[]): number {
  return Math.sqrt(v.reduce((s,x)=>s+x*x,0));
}

function cosine(a: number[], b: number[]): number {
  const dot = a.reduce((s,x,i)=>s + x*b[i], 0);
  const na = norm(a);
  const nb = norm(b);
  return dot / (na*nb + 1e-9);
}

function gate(path: PathKey, u01: number[]): number {
  const rule = GATE_RULES[path];
  const k1 = u01[idx[rule.keys[0]]];
  const k2 = u01[idx[rule.keys[1]]];
  const kAvg = (k1 + k2) / 2;

  // 门槛：关键维度太低就降权
  let g = 1.0;
  if (kAvg < 0.35) g = 0.55;      // <2.4
  else if (kAvg < 0.45) g = 0.75; // <2.8

  // 否决维度：极低再扣一点
  if (rule.veto) {
    const v = u01[idx[rule.veto]];
    if (v < 0.25) g *= 0.85; // <2.0
  }

  return g;
}

export function rankPaths(dimScores: DimScores) {
  // 1) 用户向量归一化
  const u01 = ORDER.map(k => normalize01(dimScores[k])); // 0~1

  // 2) 中心化（推荐开启：更防塌缩）
  const m = mean(u01);
  const u = u01.map(x => x - m);

  // 3) 逐路径算分
  const rows = (Object.keys(PATHS) as PathKey[]).map((key) => {
    const p = PATHS[key].slice(); // 0~5
    const sim = cosine(u, p);
    const g = gate(key, u01);
    const final = sim * g;
    return { key, sim, gate: g, final };
  });

  // 4) 排序
  rows.sort((a,b)=> b.final - a.final);

  // 5) 输出相对匹配度（0~100），避免“匹配度很低”困扰
  const max = rows[0].final;
  const min = rows[rows.length - 1].final;
  const withPercent = rows.map(r => ({
    ...r,
    percent: Math.round(((r.final - min) / (max - min + 1e-9)) * 100),
  }));

  return {
    u01,               // 0~1 的原始归一化，给结果页解释用
    ranked: withPercent,
    top1: withPercent[0],
    top2: withPercent[1],
    bottom2: withPercent.slice(-2),
  };
}
```

